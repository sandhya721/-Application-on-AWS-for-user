import { useEffect, useRef, useCallback } from 'react'

const BASE_URL = import.meta.env.VITE_API_URL || ''

/**
 * Hook to subscribe to SSE events for a job
 * @param {string|null} jobId
 * @param {Object} handlers - { onStatus, onLog, onProgress, onInit }
 */
export const useSSE = (jobId, handlers = {}) => {
  const esRef = useRef(null)
  const handlersRef = useRef(handlers)
  handlersRef.current = handlers

  const connect = useCallback(() => {
    if (!jobId) return
    const token = localStorage.getItem('token')
    if (!token) return

    const url = `${BASE_URL}/api/jobs/${jobId}/events?token=${token}`
    const es = new EventSource(url)
    esRef.current = es

    es.addEventListener('init', (e) => {
      const data = JSON.parse(e.data)
      handlersRef.current.onInit?.(data)
    })

    es.addEventListener('status', (e) => {
      const data = JSON.parse(e.data)
      handlersRef.current.onStatus?.(data)
    })

    es.addEventListener('log', (e) => {
      const data = JSON.parse(e.data)
      handlersRef.current.onLog?.(data)
    })

    es.addEventListener('progress', (e) => {
      const data = JSON.parse(e.data)
      handlersRef.current.onProgress?.(data)
    })

    es.onerror = () => {
      // Auto-reconnect is handled by the browser
    }
  }, [jobId])

  useEffect(() => {
    connect()
    return () => {
      esRef.current?.close()
      esRef.current = null
    }
  }, [connect])

  const disconnect = useCallback(() => {
    esRef.current?.close()
    esRef.current = null
  }, [])

  return { disconnect }
}
