.page {
  padding: 32px 40px;
  min-height: 100%;
  animation: fadeIn 0.3s ease;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  height: 100vh;
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 13px;
}

.spin { animation: spin 0.8s linear infinite; }

/* Top bar */
.topBar {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}

.backBtn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: none;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  padding: 7px 12px;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
}

.backBtn:hover { border-color: var(--text-secondary); color: var(--text-primary); }

.jobTitle {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.downloadBtn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--accent);
  color: #0a0a0f;
  border: none;
  border-radius: var(--radius-md);
  padding: 9px 16px;
  font-family: var(--font-display);
  font-size: 13.5px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
}

.downloadBtn:hover:not(:disabled) {
  background: #fdb94a;
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(245, 166, 35, 0.25);
}

.downloadBtn:disabled { opacity: 0.5; cursor: not-allowed; }

/* Layout */
.body {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 20px;
  align-items: start;
}

/* Left column */
.leftCol { display: flex; flex-direction: column; gap: 16px; }

.statusCard {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.statusRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.statusLabel { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

.statusValue {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text-secondary);
  text-transform: capitalize;
}

.statusActive { color: var(--status-warn); }
.statusDone   { color: var(--status-success); }
.statusFailed { color: var(--status-error); }

.progressSection { display: flex; flex-direction: column; gap: 6px; }

.progressHeader {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-secondary);
}

.progressBar {
  height: 5px;
  background: var(--bg-elevated);
  border-radius: 3px;
  overflow: hidden;
}

.progressFill {
  height: 100%;
  background: var(--accent);
  border-radius: 3px;
  transition: width 0.4s ease;
}

.progressComplete { background: var(--status-success); }

.progressPct {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  text-align: right;
}

.errorMsg {
  font-size: 12.5px;
  color: var(--status-error);
  background: var(--risk-high-bg);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  line-height: 1.5;
}

/* Risk summary */
.riskSummary {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.sectionHeading {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  display: flex;
  align-items: center;
  gap: 8px;
}

.riskRow {
  display: flex;
  align-items: center;
  gap: 10px;
}

.riskTrack {
  flex: 1;
  height: 4px;
  background: var(--bg-elevated);
  border-radius: 2px;
  overflow: hidden;
}

.riskFill { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
.riskFill_high   { background: var(--risk-high); }
.riskFill_medium { background: var(--risk-medium); }
.riskFill_low    { background: var(--risk-low); }

/* Right column */
.rightCol { display: flex; flex-direction: column; gap: 20px; }

/* Log panel */
.logPanel {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.logHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border-subtle);
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.liveDot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--status-success);
  animation: pulse-glow 2s infinite;
}

.logBody {
  height: 240px;
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.logEmpty {
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 12px 0;
}

.logLine {
  display: flex;
  gap: 10px;
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 1.5;
}

.logTime {
  color: var(--text-muted);
  flex-shrink: 0;
  font-size: 11px;
  padding-top: 1px;
}

.logMsg { color: var(--text-secondary); word-break: break-word; }

.log_info  .logMsg { color: var(--text-secondary); }
.log_warn  .logMsg { color: var(--status-warn); }
.log_error .logMsg { color: var(--status-error); }

/* Results */
.resultsPanel {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.resultCount {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2px 8px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  font-weight: normal;
}

.docList { display: flex; flex-direction: column; gap: 8px; }

.docCard {
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.docHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px;
  cursor: pointer;
  transition: background 0.12s;
  gap: 12px;
}

.docHeader:hover { background: var(--bg-card); }

.docLeft {
  display: flex;
  align-items: center;
  gap: 9px;
  min-width: 0;
}

.docIcon { color: var(--text-muted); flex-shrink: 0; }

.docName {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.docRight {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
  color: var(--text-muted);
}

.docBody {
  border-top: 1px solid var(--border-subtle);
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.docError {
  font-size: 12.5px;
  color: var(--status-error);
  background: var(--risk-high-bg);
  border-radius: var(--radius-sm);
  padding: 8px 10px;
}

.section { display: flex; flex-direction: column; gap: 6px; }

.sectionTitle {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
}

.sectionTitle_warn  { color: var(--status-warn); }
.sectionTitle_error { color: var(--status-error); }
.sectionTitle_info  { color: var(--status-info); }

.itemList {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.itemList li {
  font-size: 12.5px;
  color: var(--text-secondary);
  padding-left: 12px;
  position: relative;
  line-height: 1.5;
}

.itemList li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--text-muted);
}

/* Risk badge */
.riskBadge {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 3px 8px;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.riskHigh    { background: var(--risk-high-bg);   color: var(--risk-high);   border: 1px solid rgba(239, 68, 68, 0.2); }
.riskMedium  { background: var(--risk-medium-bg); color: var(--risk-medium); border: 1px solid rgba(245, 158, 11, 0.2); }
.riskLow     { background: var(--risk-low-bg);    color: var(--risk-low);    border: 1px solid rgba(34, 197, 94, 0.2); }
.riskUnknown { background: var(--bg-elevated);    color: var(--text-muted);  border: 1px solid var(--border); }

.mono { font-family: var(--font-mono); font-size: 11px; }
