.page {
  padding: 40px;
  max-width: 1000px;
  margin: 0 auto;
  animation: fadeIn 0.3s ease;
}

.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32px;
}

.title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.sub {
  color: var(--text-secondary);
  font-size: 13.5px;
  margin-top: 4px;
}

.newBtn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--accent);
  color: #0a0a0f;
  border: none;
  border-radius: var(--radius-md);
  padding: 10px 18px;
  font-family: var(--font-display);
  font-size: 13.5px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
}

.newBtn:hover {
  background: #fdb94a;
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(245, 166, 35, 0.25);
}

.statsRow {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 28px;
}

.statCard {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 18px 20px;
}

.statValue {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
  margin-bottom: 4px;
}

.stat_success { color: var(--status-success); }
.stat_warn    { color: var(--status-warn); }
.stat_error   { color: var(--status-error); }

.statLabel {
  font-size: 12px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.jobList {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.jobRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border-subtle);
  cursor: pointer;
  transition: background 0.12s;
  gap: 16px;
}

.jobRow:last-child { border-bottom: none; }

.jobRow:hover { background: var(--bg-elevated); }

.jobMain { flex: 1; min-width: 0; }

.jobTitle {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.jobMeta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--text-secondary);
}

.mono { font-family: var(--font-mono); font-size: 11px; }

.riskBar {
  display: flex;
  height: 3px;
  border-radius: 2px;
  overflow: hidden;
  margin-top: 8px;
  max-width: 200px;
  gap: 1px;
}

.riskHigh   { background: var(--risk-high); border-radius: 2px; }
.riskMedium { background: var(--risk-medium); border-radius: 2px; }
.riskLow    { background: var(--risk-low); border-radius: 2px; }

.jobActions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.badge {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 4px 9px;
  border-radius: var(--radius-sm);
  font-weight: 500;
  white-space: nowrap;
}

.badge_muted   { background: var(--bg-elevated); color: var(--text-muted); }
.badge_info    { background: rgba(96, 165, 250, 0.1); color: var(--status-info); }
.badge_warn    { background: var(--risk-medium-bg); color: var(--risk-medium); }
.badge_success { background: var(--risk-low-bg); color: var(--status-success); }
.badge_error   { background: var(--risk-high-bg); color: var(--status-error); }

.spin { animation: spin 0.8s linear infinite; }

.deleteBtn {
  background: none;
  border: 1px solid transparent;
  border-radius: var(--radius-sm);
  color: var(--text-muted);
  padding: 5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  transition: all 0.15s;
}

.deleteBtn:hover {
  border-color: var(--risk-high);
  color: var(--risk-high);
}

.rowArrow { color: var(--text-muted); }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  padding: 80px 20px;
  color: var(--text-muted);
  text-align: center;
}
